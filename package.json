{
	"name": "yieldkit",
	"version": "0.1.1",
	"license": "MIT",
	"description": "Composable sync and async generator helpers for iterables and DOM events",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rejth/yieldkit.git"
	},
	"homepage": "https://github.com/rejth/yieldkit#readme",
	"bugs": {
		"url": "https://github.com/rejth/yieldkit/issues"
	},
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./async": {
			"types": "./dist/async-generators.d.ts",
			"import": "./dist/async-generators.js",
			"default": "./dist/async-generators.js"
		},
		"./sync": {
			"types": "./dist/sync-generators.d.ts",
			"import": "./dist/sync-generators.js",
			"default": "./dist/sync-generators.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"test": "vitest run",
		"prepublishOnly": "npm run check && npm run test && npm run build",
		"check": "tsc -p tsconfig.json --noEmit && npm run lint",
		"lint": "oxlint src test && biome check src test",
		"lint:fix": "biome check --write src test",
		"format": "biome format --write src test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/node": "^22.8.6",
		"jsdom": "^25.0.1",
		"oxlint": "^1.68.0",
		"typescript": "^5.6.3",
		"vitest": "^2.1.9"
	}
}
